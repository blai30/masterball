{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "sortTailwindcss": {
    "functions": ["tw", "clsx"]
  },
  "arrowParens": "always",
  "bracketSpacing": true,
  "endOfLine": "lf",
  "ignorePatterns": ["**/dist/**", "**/node_modules/**", "**/out/**", "**/public/**"],
  "jsxSingleQuote": false,
  "semi": false,
  "singleQuote": true,
  "sortImports": true,
  "tabWidth": 2,
  "trailingComma": "es5",
  "useTabs": false
}
