---
import ArrowRight from '@lucide/astro/icons/arrow-right'

import EvolutionMonster from '@/components/details/evolution/EvolutionMonster.astro'
import EvolutionTransition from '@/components/details/evolution/EvolutionTransition.astro'
import type { EvolutionNodeData } from '@/lib/domain/evolution'

interface Props {
  node: EvolutionNodeData
  currentSpeciesId: number
}

const { node, currentSpeciesId } = Astro.props

const children = node.evolvesTo
const allChildrenAreLeaves = children.every((child) => child.evolvesTo.length === 0)
const useGrid = children.length >= 4 && allChildrenAreLeaves

// node.conditions describe how to evolve INTO this node, so they sit beneath
// this node's own card. Empty for the root of the chain.
const hasConditions = node.conditions.length > 0
---

<div class="flex flex-col items-center gap-4 @xl:flex-row @xl:items-start">
  <div class="flex flex-col items-center gap-2 min-w-36">
    <EvolutionMonster
      species={node.species}
      pokemon={node.pokemon}
      current={node.species.id === currentSpeciesId}
    />
    {hasConditions && <EvolutionTransition conditions={node.conditions} />}
  </div>

  {
    children.length > 0 &&
      (useGrid ? (
        <div class="flex flex-col items-center gap-4 @xl:flex-row @xl:items-start">
          <ArrowRight class="size-6 shrink-0 rotate-90 text-zinc-400 @xl:mt-20 @xl:rotate-0 dark:text-zinc-500" />
          <div class="flex flex-wrap gap-x-4 gap-y-10">
            {children.map((child) => (
              <Astro.self node={child} currentSpeciesId={currentSpeciesId} />
            ))}
          </div>
        </div>
      ) : (
        <div class="flex flex-row items-start gap-4 @xl:flex-col">
          {children.map((child) => (
            <div class="flex flex-col items-center gap-4 @xl:flex-row @xl:items-start">
              <ArrowRight class="size-6 shrink-0 rotate-90 text-zinc-400 @xl:mt-20 @xl:rotate-0 dark:text-zinc-500" />
              <Astro.self node={child} currentSpeciesId={currentSpeciesId} />
            </div>
          ))}
        </div>
      ))
  }
</div>
