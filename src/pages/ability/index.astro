---
import pMap from 'p-map'
import type { Ability } from 'pokedex-promise-v2'
import Layout from '@/layouts/Layout.astro'
import AppShell from '@/components/AppShell'
import InfoCardGrid from '@/components/compounds/InfoCardGrid'
import pokeapi from '@/lib/api/pokeapi'
import { getTranslation } from '@/lib/utils/pokeapi-helpers'

const abilityList = import.meta.env.DEV
  ? await pokeapi.getList('ability', 40, 0)
  : await pokeapi.getList('ability', 600, 0)

const abilities = await pMap(
  abilityList.results,
  (result) => pokeapi.getResource<Ability>(result.url),
  { concurrency: 20 }
)

const abilitiesData = abilities
  .filter(
    (resource) =>
      resource.is_main_series &&
      resource.names.some((name) => name.language.name === 'en')
  )
  .map((resource) => ({
    id: resource.id,
    slug: resource.name,
    name: getTranslation(resource.names, 'name')!,
    defaultDescription: getTranslation(resource.effect_entries, 'short_effect') ?? '',
    flavorTextEntries: resource.flavor_text_entries.filter((e) => e.language.name === 'en'),
  }))
  .sort((a, b) => a.name.localeCompare(b.name))
---

<Layout title="Ability List">
  <AppShell pathname={Astro.url.pathname} client:load>
    <div class="mx-auto w-full max-w-384">
      <InfoCardGrid data={abilitiesData} filterByVersionGroup={true} client:load />
    </div>
  </AppShell>
</Layout>
