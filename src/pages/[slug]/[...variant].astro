---
import pMap from 'p-map'
import type { EggGroup, GrowthRate, Pokemon, PokemonForm, PokemonSpecies } from 'pokedex-promise-v2'
import Layout from '../../layouts/Layout.astro'
import AppShell from '@/components/AppShell'
import pokeapi from '@/lib/api/pokeapi'
import { getTestSpeciesList } from '@/lib/providers'
import { getMonstersBySpecies, getTranslation, TypeLabels, type TypeKey } from '@/lib/utils/pokeapi-helpers'
import { excludedForms, excludedVariants } from '@/lib/utils/excluded-slugs'
import MonsterHero from '@/components/details/MonsterHero'
import MonsterMetadata from '@/components/details/MonsterMetadata'
import StatsSection from '@/components/details/stats/StatsSection'
import TypeEffectivenessSection from '@/components/details/typeEffectiveness/TypeEffectivenessSection'
import AbilitiesSection from '@/components/details/abilities/AbilitiesSection'
import LocationsSection from '@/components/details/locations/LocationsSection'
import EvolutionSection from '@/components/details/evolution/EvolutionSection'
import CosmeticsSection from '@/components/details/cosmetics/CosmeticsSection'
import LocalizationSection from '@/components/details/localization/LocalizationSection'
import MovesSection from '@/components/details/moves/MovesSection'
import VariantCardSelector from '@/components/compounds/VariantCardSelector'
import {
  buildTypeRelations,
  buildAbilitiesMap,
  buildEvolutionTree,
} from '@/lib/utils/detail-helpers'
import {
  buildLocationRows,
} from '@/lib/utils/location-helpers'
import {
  buildMoveRowsByMethod,
} from '@/lib/utils/moves-helpers'

export async function getStaticPaths() {
  const speciesList = import.meta.env.DEV
    ? await getTestSpeciesList()
    : await pokeapi.getList('pokemon-species', 1025, 0)

  const species = await pMap(
    speciesList.results,
    (result) => pokeapi.getResource<PokemonSpecies>(result.url),
    { concurrency: 20 }
  )

  return species.flatMap((specie) =>
    specie.varieties
      .filter((v) => !excludedVariants.includes(v.pokemon.name))
      .map((variant) => ({
        params: {
          slug: specie.name,
          variant: variant.is_default ? undefined : variant.pokemon.name,
        },
      }))
  )
}

const { slug, variant: variantKey } = Astro.params

const species = await pokeapi.getByName<PokemonSpecies>('pokemon-species', slug)
const pokemonUrl = species.varieties
  .filter((v) => !excludedVariants.includes(v.pokemon.name))
  .find((v) => (variantKey ? v.pokemon.name === variantKey : v.is_default))!.pokemon.url
const pokemon = await pokeapi.getResource<Pokemon>(pokemonUrl)

// Get all variants for selector
const monsters = await getMonstersBySpecies(species)

// Get forms
const forms = await pMap(
  pokemon.forms.filter((form) => !excludedForms.includes(form.name)),
  (form) => pokeapi.getByName<PokemonForm>('pokemon-form', form.name),
  { concurrency: 20 }
)

const form =
  pokemon.is_default || species.name === pokemon.name
    ? undefined
    : forms.find((f) => f.name === variantKey || f.name === pokemon.name)

// Build section data in parallel
const [typeRelations, abilitiesMap, eggGroups, growthRate, evolutionRoot, locationRows, moveRowsByMethod] = await Promise.all([
  buildTypeRelations(pokemon),
  buildAbilitiesMap(pokemon),
  pMap(
    species.egg_groups,
    (eg) => pokeapi.getResource<EggGroup>(eg.url),
    { concurrency: 4 }
  ),
  pokeapi.getResource<GrowthRate>(species.growth_rate.url),
  buildEvolutionTree(species),
  buildLocationRows(pokemon),
  buildMoveRowsByMethod(pokemon),
])

// Build metadata
const imageId = species.id.toString().padStart(4, '0')
const imageUrl = `https://raw.githubusercontent.com/blai30/PokemonSpritesDump/refs/heads/main/sprites/sprite_${imageId}_s0.webp`
const name = getTranslation(species.names, 'name')!
const description = pokemon.types.map((t) => TypeLabels[t.type.name as TypeKey]).join('/')
const title = `${name} #${imageId}`
---

<Layout {title} description={description} imageUrl={imageUrl}>
  <AppShell pathname={Astro.url.pathname} client:load>
    <div class="flex w-full flex-1 flex-col gap-6">
      <div class="grow">
        <div class="mx-auto max-w-384">
          <div class="flex overflow-x-auto">
            <div class="@container grow">
              <VariantCardSelector pathname={Astro.url.pathname} monsters={monsters} className="min-w-full justify-center-safe whitespace-nowrap" client:load />
            </div>
          </div>
        </div>
      </div>

      <div class="flex w-full flex-col gap-4 xl:max-w-none">
        <section class="@container mx-auto w-full max-w-384">
          <div class="grid grid-cols-2 gap-4 @3xl:grid-cols-4 @[88rem]:grid-cols-8">
            <MonsterHero species={species} pokemon={pokemon} form={form} className="col-span-2" client:load />
            <MonsterMetadata
              species={species}
              pokemon={pokemon}
              eggGroups={eggGroups}
              growthRate={growthRate}
              client:load
            />
          </div>
        </section>

        <section class="mx-auto w-full max-w-384">
          <div class="flex w-full flex-col gap-4 xl:flex-row">
            <div class="flex w-full flex-col gap-4">
              <StatsSection pokemon={pokemon} client:load />
              <TypeEffectivenessSection typeRelations={typeRelations} client:load />
              <AbilitiesSection abilitiesMap={abilitiesMap} client:load />
              <LocationsSection rows={locationRows} client:load />
              <EvolutionSection evolutionRoot={evolutionRoot} client:load />
              {forms.length > 1 && <CosmeticsSection pokemon={pokemon} forms={forms} client:load />}
              <LocalizationSection species={species} client:load />
            </div>
            <div class="flex w-full flex-col gap-6">
              <MovesSection moveRowsByMethod={moveRowsByMethod} client:load />
            </div>
          </div>
        </section>
      </div>
    </div>
  </AppShell>
</Layout>
