---
import pMap from 'p-map'
import type {
  EggGroup,
  GrowthRate,
  Pokemon,
  PokemonForm,
  PokemonSpecies,
} from 'pokedex-promise-v2'
import Layout from '@/layouts/Layout.astro'
import Shell from '@/components/Shell.astro'
import pokeapi from '@/lib/api/pokeapi'
import { getSpeciesList } from '@/lib/providers'
import { buildAbilitiesMap } from '@/lib/domain/abilities'
import { getCombinedEffectiveness, initTypes, type TypeRelation } from '@/lib/domain/effectiveness'
import { buildEvolutionTree } from '@/lib/domain/evolution'
import { buildLocationRows } from '@/lib/domain/locations'
import { buildMovesData } from '@/lib/domain/moves'
import { buildBaseStats } from '@/lib/domain/stats'
import { TYPES, TYPE_KEYS, type TypeKey } from '@/lib/domain/types'
import { getMonstersBySpecies, getTranslation } from '@/lib/utils/pokeapi-helpers'
import { excludedForms, excludedVariants } from '@/lib/utils/excluded-slugs'
import MonsterHero from '@/components/details/MonsterHero.astro'
import MonsterMetadata from '@/components/details/MonsterMetadata.astro'
import StatsSection from '@/components/details/stats/StatsSection'
import TypeEffectivenessSection from '@/components/details/typeEffectiveness/TypeEffectivenessSection.astro'
import AbilitiesSection from '@/components/details/abilities/AbilitiesSection'
import LocationsSection from '@/components/details/locations/LocationsSection'
import EvolutionSection from '@/components/details/evolution/EvolutionSection.astro'
import CosmeticsSection from '@/components/details/cosmetics/CosmeticsSection.astro'
import LocalizationSection from '@/components/details/localization/LocalizationSection.astro'
import MovesSection from '@/components/details/moves/MovesSection'
import VariantCardSelector from '@/components/compounds/VariantCardSelector'

export async function getStaticPaths() {
  const speciesList = await getSpeciesList()

  const species = await pMap(
    speciesList.results,
    (result) => pokeapi.getResource<PokemonSpecies>(result.url),
    { concurrency: 10 }
  )

  return species.flatMap((specie) =>
    specie.varieties
      .filter((v) => !excludedVariants.includes(v.pokemon.name))
      .map((variant) => ({
        params: {
          slug: specie.name,
          variant: variant.is_default ? undefined : variant.pokemon.name,
        },
        props: { species: specie },
      }))
  )
}

export interface Props {
  species: PokemonSpecies
}

const { variant } = Astro.params
const { species } = Astro.props
const pokemonUrl = species.varieties
  .filter((v) => !excludedVariants.includes(v.pokemon.name))
  .find((v) => (variant ? v.pokemon.name === variant : v.is_default))!.pokemon
  .url
const pokemon = await pokeapi.getResource<Pokemon>(pokemonUrl)

// Get all variants for selector
const monsters = await getMonstersBySpecies(species)

// Get forms
const forms = await pMap(
  pokemon.forms.filter((form) => !excludedForms.includes(form.name)),
  (form) => pokeapi.getByName<PokemonForm>('pokemon-form', form.name),
  { concurrency: 10 }
)

const form =
  pokemon.is_default || species.name === pokemon.name
    ? undefined
    : forms.find((f) => f.name === variant || f.name === pokemon.name)

// Fetch all 18 types once (cached across the entire build) and pre-compute effectiveness.
const allTypes = await initTypes()
// Compute type relations from pre-fetched types and pre-computed effectiveness.
const typeKeys = pokemon.types.map((t) => t.type.name as TypeKey)
const effectiveness = getCombinedEffectiveness(typeKeys)
const typeRelations: TypeRelation[] = TYPE_KEYS.map((typeKey) => ({
  type: allTypes[typeKey],
  effectiveness: effectiveness[typeKey],
}))

// Build section data in parallel
const [
  abilitiesMap,
  eggGroups,
  growthRate,
  evolutionRoot,
  locationRows,
  movesData,
] = await Promise.all([
  buildAbilitiesMap(pokemon),
  pMap(species.egg_groups, (eg) => pokeapi.getResource<EggGroup>(eg.url), {
    concurrency: 4,
  }),
  pokeapi.getResource<GrowthRate>(species.growth_rate.url),
  buildEvolutionTree(species),
  buildLocationRows(pokemon),
  buildMovesData(pokemon, 'scarlet-violet'),
])

// Metadata
const imageId = species.id.toString().padStart(4, '0')
const imageUrl = `https://raw.githubusercontent.com/blai30/PokemonSpritesDump/refs/heads/main/sprites/sprite_${imageId}_s0.webp`
const name = getTranslation(species.names, 'name')!
const description = pokemon.types
  .map((t) => TYPES[t.type.name as TypeKey])
  .join('/')
const title = `${name} #${imageId}`
---

<Layout {title} description={description} imageUrl={imageUrl}>
  <Shell>
    <div class="flex w-full flex-1 flex-col gap-6">
      <div class="grow">
        <div class="mx-auto max-w-384">
          <div class="flex overflow-x-auto">
            <div class="@container grow">
              <VariantCardSelector
                pathname={Astro.url.pathname}
                monsters={monsters}
                className="min-w-full justify-center-safe whitespace-nowrap"
                client:visible
              />
            </div>
          </div>
        </div>
      </div>

      <div class="flex w-full flex-col gap-4 xl:max-w-none">
        <section class="@container mx-auto w-full max-w-384">
          <div
            class="grid grid-cols-2 gap-4 @3xl:grid-cols-4 @[88rem]:grid-cols-8"
          >
            <MonsterHero
              species={species}
              pokemon={pokemon}
              form={form}
              class="col-span-2"
            />
            <MonsterMetadata
              species={species}
              pokemon={pokemon}
              eggGroups={eggGroups}
              growthRate={growthRate}
            />
          </div>
        </section>

        <section class="mx-auto w-full max-w-384">
          <div class="flex w-full flex-col gap-4 xl:flex-row">
            <div class="flex w-full flex-col gap-4">
              <StatsSection stats={buildBaseStats(pokemon)} client:visible />
              <TypeEffectivenessSection typeRelations={typeRelations} />
              <AbilitiesSection abilitiesMap={abilitiesMap} client:visible />
              <LocationsSection rows={locationRows} client:visible />
              <EvolutionSection
                evolutionRoot={evolutionRoot}
                currentSpeciesId={species.id}
              />
              {
                forms.length > 1 && (
                  <CosmeticsSection pokemon={pokemon} forms={forms} />
                )
              }
              <LocalizationSection species={species} />
            </div>
            <div class="flex w-full flex-col gap-6">
              <MovesSection
                learnset={movesData.learnset}
                defaultRows={movesData.defaultRows}
                defaultVersionGroup="scarlet-violet"
                client:visible
              />
            </div>
          </div>
        </section>
      </div>
    </div>
  </Shell>
</Layout>
