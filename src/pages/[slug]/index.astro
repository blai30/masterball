---
import pMap from 'p-map'
import type { Pokemon, PokemonSpecies } from 'pokedex-promise-v2'
import Layout from '@/layouts/Layout.astro'
import AppShell from '@/components/AppShell'
import Detail from '@/pages/[slug]/_detail.astro'
import pokeapi from '@/lib/api/pokeapi'
import { getTestSpeciesList } from '@/lib/providers'
import {
  getTranslation,
  TypeLabels,
  type TypeKey,
} from '@/lib/utils/pokeapi-helpers'
import { excludedVariants } from '@/lib/utils/excluded-slugs'

type PageProps = {
  title: string
  description: string
  imageUrl: string
}

export async function getStaticPaths() {
  const speciesList = import.meta.env.DEV
    ? await getTestSpeciesList()
    : await pokeapi.getList('pokemon-species', 1025, 0)

  const species = await pMap(
    speciesList.results,
    (result) => pokeapi.getResource<PokemonSpecies>(result.url),
    {
      concurrency: 20,
    }
  )

  const staticPaths = await pMap(
    species,
    async (specie) => {
      const defaultVariant = specie.varieties
        .filter((v) => !excludedVariants.includes(v.pokemon.name))
        .find((variant) => variant.is_default)
      if (!defaultVariant) return undefined

      const pokemon = await pokeapi.getResource<Pokemon>(
        defaultVariant.pokemon.url
      )
      const imageId = specie.id.toString().padStart(4, '0')

      return {
        params: { slug: specie.name },
        props: {
          title: `${getTranslation(specie.names, 'name')} #${imageId}`,
          description: pokemon.types
            .map((t) => TypeLabels[t.type.name as TypeKey])
            .join('/'),
          imageUrl: `https://raw.githubusercontent.com/blai30/PokemonSpritesDump/refs/heads/main/sprites/sprite_${imageId}_s0.webp`,
        } satisfies PageProps,
      }
    },
    {
      concurrency: 20,
    }
  )

  return staticPaths.filter(
    (entry): entry is { params: { slug: string }; props: PageProps } =>
      entry !== undefined
  )
}

const { slug } = Astro.params
const { title, description, imageUrl } = Astro.props

if (!slug) {
  throw new Error('Missing slug route parameter.')
}
---

<Layout title={title} description={description} imageUrl={imageUrl}>
  <AppShell pathname={Astro.url.pathname} client:load>
    <Detail slug={slug} />
  </AppShell>
</Layout>
