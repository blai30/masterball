---
import pMap from 'p-map'
import type { Move } from 'pokedex-promise-v2'
import Layout from '@/layouts/Layout.astro'
import Shell from '@/components/Shell.astro'
import MoveCardGrid from '@/components/compounds/MoveCardGrid'
import pokeapi from '@/lib/api/pokeapi'
import { getMoveList } from '@/lib/providers'
import { getTranslation } from '@/lib/utils/pokeapi-helpers'

const moveList = await getMoveList()

const moves = await pMap(
  moveList.results,
  (result) => pokeapi.getResource<Move>(result.url),
  { concurrency: 10 }
)

const movesData = moves
  .filter((resource) =>
    resource.names.some((name) => name.language.name === 'en')
  )
  .map((resource) => ({
    id: resource.id.toString(),
    slug: resource.name,
    name: getTranslation(resource.names, 'name')!,
    defaultDescription:
      getTranslation(resource.effect_entries, 'short_effect') ?? '',
    flavorTextEntries: resource.flavor_text_entries.filter(
      (e) => e.language.name === 'en'
    ),
    type: resource.type.name,
    damageClass: resource.damage_class.name,
    power: resource.power || undefined,
    accuracy: resource.accuracy || undefined,
    pp: resource.pp!,
  }))
  .sort((a, b) => a.name.localeCompare(b.name))
---

<Layout title="Move List">
  <Shell>
    <div class="mx-auto w-full max-w-384">
      <MoveCardGrid data={movesData} filterByVersionGroup={true} client:load />
    </div>
  </Shell>
</Layout>
